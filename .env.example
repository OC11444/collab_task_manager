# Django Core
# For local dev, keep DEBUG=True. Change to False in Render dashboard.
DEBUG=True
SECRET_KEY=your-secret-key-here
# USE SPACES, NOT COMMAS (because of your settings.py .split(" ") logic)
ALLOWED_HOSTS=127.0.0.1 localhost .onrender.com

# Database (Local)
DB_NAME=collab_db
DB_USER=root
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=3306

# Database (Production)
# Render will provide this automatically.
DATABASE_URL=

# Email Settings
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here

# Frontend Sync
# Your GitHub Pages link goes here for production testing
FRONTEND_URL=http://localhost:8080